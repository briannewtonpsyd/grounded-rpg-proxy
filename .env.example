# ============================================================================
# Grounding proxy — configuration
# Copy to `.env` and fill in. Everything is tunable here so we can experiment
# without editing code.
# ============================================================================

# --- Backend selection ------------------------------------------------------
# lightrag         -> KG + vector RAG over local indexes. THE backend — use this.
#                     One Gemini key by default. Ingest via the dashboard or
#                     `python -m app.ingest --game <slug> books/<System>/`
# gemini_filesearch-> DEPRECATED (Gemini File Search; pure-vector, no rerank)
# notebooklm       -> DEPRECATED (unofficial NotebookLM; 4k input cap, ~40s)
BACKEND=lightrag

# --- LightRAG backend -------------------------------------------------------
# EASY (default): one Gemini key does everything (embeddings + generation), and on
# the free tier you can't be billed. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=                 # the one key the easy path needs
GEMINI_DEFAULT_GAME=            # default game slug when PUM sends an unknown model
LIGHTRAG_DATA_DIR=lightrag_data # one subdir per game (the working_dir)
LIGHTRAG_QUERY_MODE=mix         # mix (KG+vector) | hybrid | local | global | naive
#                                 (RAG-only indexes are always queried 'naive')

# --- Cost / quality dials (see README "Cost & quality") ---------------------
# RAG-only: skip the knowledge graph at ingest. true = ~cents/library (vector
# search). false = full KG (~$1-6/library) for richer, relationship-aware grounding.
LIGHTRAG_SKIP_KG=true
# Embedding provider: gemini (one key) | openai (needs OPENAI_API_KEY, slightly better).
LIGHTRAG_EMBEDDING_PROVIDER=gemini
# Hard ingest cost ceiling in USD (0 = none). Stops a KG ingest before it crosses this.
INGEST_MAX_COST_USD=0
# Only needed if LIGHTRAG_EMBEDDING_PROVIDER=openai (the quality path):
OPENAI_API_KEY=                 # embeddings (text-embedding-3-large)

# Generation model — swap to experiment. gemini | openai | anthropic | openrouter | custom
LIGHTRAG_LLM_PROVIDER=gemini
LIGHTRAG_LLM_MODEL=gemini-2.5-flash
# Gemini reasoning effort: none disables "thinking" (~4x faster; recommended).
LIGHTRAG_REASONING_EFFORT=none
# OpenRouter: one key drives generation + KG ingest (set the LLM provider to
# 'openrouter', use "vendor/model" ids e.g. anthropic/claude-haiku-4.5) AND embeddings
# (set LIGHTRAG_EMBEDDING_PROVIDER=openrouter, e.g. openai/text-embedding-3-large) — a
# true one-key setup. No reranking. (Blank => falls back to LIGHTRAG_LLM_API_KEY.)
OPENROUTER_API_KEY=
# For provider=custom (any other OpenAI-compatible endpoint):
LIGHTRAG_LLM_BASE_URL=
LIGHTRAG_LLM_API_KEY=
# For provider=anthropic (Claude). Note: Claude is stricter about creative roleplay
# and may need prompt tuning; Gemini-flash/GPT-4o-mini work out of the box.
ANTHROPIC_API_KEY=

# Reranking (free tier). Set a key to enable; provider: cohere | jina.
LIGHTRAG_ENABLE_RERANK=true
RERANK_PROVIDER=cohere
RERANK_API_KEY=
RERANK_MODEL=rerank-v3.5
# KG-steering: inject a location's canonical NPCs so generation prefers them.
LIGHTRAG_KG_STEERING=false
LIGHTRAG_STEERING_CHEAP=true


# --- Required ---------------------------------------------------------------
# The notebook holding your grounded sourcebooks. Get it from the NotebookLM
# URL ( notebooklm.google.com/notebook/<THIS-PART> ) or `notebooklm notebook list`.
TARGET_NOTEBOOK_ID=

# Local port PUM Companion will point at (http://localhost:<PORT>/v1).
PORT=8000

# --- Authentication ---------------------------------------------------------
# Preferred: run `notebooklm login` once (writes ~/.notebooklm/.../storage_state.json).
# Nothing to set here in that case — the SDK finds it automatically.
#
# Alternatives (uncomment if you don't use the default profile location):
# NOTEBOOKLM_HOME=/custom/path/.notebooklm
# NOTEBOOKLM_PROFILE=default
# NOTEBOOKLM_AUTH_JSON={"cookies":[...]}   # inline auth, no file needed

# --- Prompt construction ----------------------------------------------------
# How the proxy turns PUM's {system + messages} into a single NotebookLM query.
#   combined  -> "Instruction:\n<system>\n\n---\n\n<last user message>"  (default)
#   last_user -> only the final user message (literal OpenAI->RAG passthrough)
#   full      -> the whole transcript rendered as Role: content lines
FORWARD_MODE=combined

# Fixed persona applied once at startup via chat.configure(). This is the single
# biggest lever for reducing refusals + citation noise. Leave blank to skip.
PERSONA=You are assisting a solo tabletop RPG session. Treat the notebook sources as the game's rulebook, setting, and canon. Answer in-world and stay consistent with the sources; you may creatively extrapolate where the sources are silent. Write clean prose with no citation markers, footnotes, or "according to the sources" preambles.

# NotebookLM chat goal: default | custom | learning_guide
# (Leave as "default"; if PERSONA is set the proxy auto-selects CUSTOM for you.)
CHAT_GOAL=default
# Response verbosity: default | longer | shorter
RESPONSE_LENGTH=default

# --- Output cleanup ---------------------------------------------------------
# Strip [1] [2,3] style citation markers from the answer before returning it.
STRIP_CITATIONS=true

# --- Conversation isolation -------------------------------------------------
# NotebookLM extends one running conversation per notebook by default, so
# unrelated PUM chains would contaminate each other. true = delete the prior
# conversation before each request so every call starts fresh (turn_number=1).
# NOTE: this is destructive to that notebook's transient chat history (which you
# don't use manually). Set false to keep a single growing conversation instead.
NEW_CONVERSATION_PER_REQUEST=true

# Per-request timeout (seconds) for a NotebookLM chat call.
REQUEST_TIMEOUT=120

# --- Model identity ---------------------------------------------------------
# Alias for the DEFAULT notebook (TARGET_NOTEBOOK_ID). /v1/models also lists
# every notebook in your account as its own model (a slug of its title, e.g.
# "forbidden-lands"), so PUM can switch the grounded source via the model field.
# Sending this alias (or any unknown model) uses the default notebook.
MODEL_NAME=notebooklm-grounded

# --- Refusal handling (surface-as-is for v1) --------------------------------
# We DETECT refusals so they're visible/loggable, but do not auto-route away.
# Comma-separated, case-insensitive substrings.
REFUSAL_MARKERS=the sources do not contain,the provided sources do not,i don't have information,i do not have information,no information about,the sources don't mention,cannot find information

# --- Telemetry / audit ------------------------------------------------------
# Every /v1/chat/completions call is logged as one JSON line: the exact PUM
# payload, the query we sent NotebookLM, raw vs cleaned answer, refusal/fallback
# flags, turn number, latency, status. This is the lens for tuning.
AUDIT_LOG=true
AUDIT_LOG_PATH=logs/audit.jsonl
# Capture full message bodies (not just previews). Set false to log only summaries.
AUDIT_LOG_BODIES=true
# Console log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Gemini (File Search backend + fallback) --------------------------------
# Used by BACKEND=gemini_filesearch (and the optional NotebookLM refusal fallback).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# File Search: chunks retrieved per query, default game when model is unknown,
# and whether to append a "Sources:" list to answers.
FILESEARCH_TOP_K=10
GEMINI_DEFAULT_GAME=
FILESEARCH_SHOW_CITATIONS=false

# NotebookLM-only: transparently re-answer a detected refusal with Gemini.
ENABLE_GEMINI_FALLBACK=false
